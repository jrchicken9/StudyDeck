# Copy to `.env` for local Vite dev. On Railway, set the same keys as service variables.

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key

# Optional aliases (also read at container start by inject-railway-supabase-env.mjs):
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# Supabase Dashboard → Authentication → URL configuration:
#   Site URL: your Railway URL (e.g. https://your-service.up.railway.app)
#   Redirect URLs: include that URL and http://localhost:5173 for local Vite.
